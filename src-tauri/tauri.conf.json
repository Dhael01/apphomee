{
  "productName": "pawnest",
  "version": "1.0.0",
  "identifier": "com.pawnest.app",
  "build": {
    "frontendDist": "../www"
  },
  "app": {
    "windows": [
      {
        "title": "pawnest",
        "width": 480,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
